# ─────────────────────────────────────────────────────────────────────
# SecOps Universal Monitor — Variables de Entorno (plantilla)
# ─────────────────────────────────────────────────────────────────────
# 1. Copia este archivo:  cp .env.example .env
# 2. Edita los valores sensibles antes de desplegar en producción.
# 3. Nunca subas .env al repositorio.

# ── Seguridad ────────────────────────────────────────────────────────
# Genera un valor seguro: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=cambia-esto-en-produccion-usa-un-hex-aleatorio-de-64-chars

# Directorio de datos persistentes (Docker usa /app/data automáticamente)
DATA_DIR=.

# ── Admin inicial (solo se crea si no existe) ────────────────────────
ADMIN_EMAIL=admin@secops.local
ADMIN_PASSWORD=Admin1234!
ADMIN_NAME=Administrador SecOps

# ── URLs de Microservicios ───────────────────────────────────────────
# En Docker Compose se sobreescriben automáticamente.
MASKING_SERVICE_URL=http://localhost:8001
MONITOR_SERVICE_URL=http://localhost:8002

# ── PostgreSQL ───────────────────────────────────────────────────────
PG_HOST=localhost
PG_PORT=5432
PG_USER=postgres
PG_PASSWORD=postgres
PG_DB=postgres

# ── MySQL ────────────────────────────────────────────────────────────
MYSQL_HOST=localhost
MYSQL_PORT=3306
MYSQL_USER=root
MYSQL_PASSWORD=root
MYSQL_DB=mysql

# ── SQL Server ─────────────────────────────────────────────────────
MSSQL_HOST=localhost
MSSQL_PORT=1433
MSSQL_USER=sa
MSSQL_PASSWORD=StrongPassword123!
MSSQL_DB=master

# ── MongoDB ──────────────────────────────────────────────────────────
MONGO_URI=mongodb://localhost:27017/
MONGO_DB=admin

# ── Redis ──────────────────────────────────────────────────────────
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_DB=0
REDIS_PASSWORD=

# ── Neo4j ──────────────────────────────────────────────────────────
NEO4J_URI=bolt://localhost:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=password

# ── Google OAuth2 ──────────────────────────────────────────────────
# Crea credenciales en: https://console.cloud.google.com/apis/credentials
GOOGLE_CLIENT_ID=tu-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=tu-client-secret
GOOGLE_REDIRECT_URI=http://localhost:8000/auth/google/callback

# ── Session Secret (para middleware de Starlette OAuth) ─────────────
SESSION_SECRET_KEY=cambia-esto-en-produccion-usa-un-hex-aleatorio-de-64-chars
